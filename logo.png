:root{--green:#75ff00;--blue:#00d9ff;--dark:#020702;--panel:rgba(0,14,10,.82);--text:#f4fff1}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:radial-gradient(circle at top,#08250c 0%,#020702 42%,#000 100%);color:var(--text);font-family:Arial,Helvetica,sans-serif;overflow-x:hidden}.scanlines{pointer-events:none;position:fixed;inset:0;background:linear-gradient(rgba(255,255,255,.025) 50%,rgba(0,0,0,.03) 50%);background-size:100% 4px;z-index:999;mix-blend-mode:overlay}.energy-grid{position:fixed;inset:-20%;background:radial-gradient(circle,rgba(117,255,0,.16),transparent 35%),linear-gradient(90deg,transparent 95%,rgba(117,255,0,.08) 96%),linear-gradient(0deg,transparent 95%,rgba(117,255,0,.08) 96%);background-size:auto,80px 80px,80px 80px;animation:drift 18s linear infinite;opacity:.55;z-index:-1}.site-header{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:20px 28px;position:sticky;top:0;z-index:20;background:rgba(0,0,0,.68);backdrop-filter:blur(12px);border-bottom:1px solid rgba(117,255,0,.25)}.brand-name,.legacy{color:var(--green);font-weight:900;text-shadow:0 0 16px rgba(117,255,0,.8)}nav{display:flex;gap:18px;flex-wrap:wrap;justify-content:center}nav a,a{color:var(--green);text-decoration:none;font-weight:800}main{max-width:1100px;margin:auto;padding:42px 18px}.hero,.panel{border:1px solid rgba(117,255,0,.28);border-radius:28px;background:linear-gradient(145deg,rgba(0,0,0,.74),rgba(0,30,20,.55));box-shadow:0 0 50px rgba(117,255,0,.16);margin:34px auto;padding:48px 28px;text-align:center;position:relative;overflow:hidden}.hero:before,.panel:before{content:"";position:absolute;inset:-2px;background:linear-gradient(120deg,transparent,rgba(117,255,0,.18),transparent);transform:translateX(-100%);animation:sweep 5.5s infinite}.transmission,.eyebrow{text-transform:uppercase;letter-spacing:3px;color:var(--green);font-weight:900;text-shadow:0 0 16px var(--green)}.logo{width:260px;max-width:76%;border-radius:50%;filter:drop-shadow(0 0 30px rgba(117,255,0,.9));margin:24px auto}.pulse{animation:pulse 2.8s ease-in-out infinite}h1{font-size:clamp(42px,8vw,88px);line-height:.95;margin:20px auto;text-transform:uppercase;text-shadow:0 0 28px rgba(117,255,0,.4)}h2{font-size:clamp(30px,5vw,58px);line-height:1;margin:14px auto;text-transform:uppercase}p{font-size:20px;line-height:1.55;color:#d8e6d3;max-width:780px;margin:22px auto}.hero-buttons a{display:inline-block;margin:10px;padding:15px 26px;border-radius:999px;background:var(--green);color:#071000;box-shadow:0 0 25px rgba(117,255,0,.5)}.hero-buttons .ghost{background:transparent;color:var(--green);border:2px solid var(--green)}.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;margin-top:28px}.cards article{padding:24px;border:1px solid rgba(117,255,0,.28);border-radius:18px;background:rgba(0,0,0,.48);font-size:20px;font-weight:900;transition:.25s}.cards article:hover{transform:translateY(-8px) scale(1.02);box-shadow:0 0 30px rgba(117,255,0,.35)}.split{display:grid;grid-template-columns:1.2fr .8fr;gap:26px;align-items:center}.price-box{display:grid;grid-template-columns:1fr;gap:6px;border:2px solid var(--green);border-radius:22px;padding:26px;background:rgba(117,255,0,.08);box-shadow:0 0 30px rgba(117,255,0,.28)}.price-box strong{font-size:54px;color:var(--green);line-height:1}.price-box span{margin-bottom:16px;color:#fff;font-weight:900}.contact{box-shadow:0 0 50px rgba(0,217,255,.15)}footer{text-align:center;color:#8cff4d;padding:36px;font-weight:900}.announcement{position:fixed;inset:0;background:rgba(0,0,0,.86);display:flex;align-items:center;justify-content:center;z-index:1000;padding:18px;backdrop-filter:blur(8px)}.announcement-box{position:relative;max-width:760px;width:min(94vw,760px);max-height:92vh;overflow:auto;background:#030703;border:4px solid var(--green);border-radius:20px;box-shadow:0 0 55px var(--green);padding:12px;animation:pop .5s ease}.announcement-box img{width:100%;display:block;border-radius:12px}.popup-label{position:sticky;top:0;z-index:2;background:rgba(0,0,0,.78);color:var(--green);font-weight:900;text-transform:uppercase;letter-spacing:2px;padding:8px;border-radius:10px;margin-bottom:8px}#closePopup{position:absolute;top:12px;right:12px;z-index:5;background:var(--green);border:none;color:#000;width:46px;height:46px;border-radius:50%;font-size:34px;font-weight:900;cursor:pointer;box-shadow:0 0 24px var(--green)}.reopen{position:fixed;right:18px;bottom:18px;z-index:50;background:var(--green);color:#031000;border:none;border-radius:999px;padding:14px 18px;font-weight:900;box-shadow:0 0 30px rgba(117,255,0,.6);cursor:pointer;display:none}.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}.reveal.visible{opacity:1;transform:translateY(0)}@keyframes pulse{0%,100%{transform:scale(1);filter:drop-shadow(0 0 22px rgba(117,255,0,.7))}50%{transform:scale(1.04);filter:drop-shadow(0 0 45px rgba(117,255,0,1))}}@keyframes sweep{0%{transform:translateX(-100%)}48%,100%{transform:translateX(100%)}}@keyframes pop{from{opacity:0;transform:scale(.88) rotate(-1deg)}to{opacity:1;transform:scale(1) rotate(0)}}@keyframes drift{from{transform:translate3d(0,0,0)}to{transform:translate3d(80px,80px,0)}}@media(max-width:760px){.site-header{flex-direction:column;padding:14px}.legacy{display:none}.split{grid-template-columns:1fr}main{padding:20px 12px}.hero,.panel{padding:34px 18px}p{font-size:17px}.announcement-box{max-height:88vh}}
